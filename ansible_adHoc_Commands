# This is regarding Ad-Hoc Command for the ansible to connect with remote/managed host from the central node to configure.
########################


Syntax : ansible -b(for sudo) -i  <Inventory file>  -m <Modules> -a <Options>
-m default : ansible.builtin.command, used  inline like, command, shell, service, user,apt
-a : the default command related to shell, service, user, apt 

#To create file in remote host which is group in inventory file inventory.ini with 'remote'.
ansible -i inventory.ini all/remote -m shell -a 'touch filename.ext'

#To check the status of disk and ram in remote hosts.
ansible -i inventory.ini all -m shell -a 'df -h && free -h'

#To install a package or a service nginx or mysql
ansible -b -i inventory.ini remote -m apt/yum/dnf -a 'name=mysql/nginx state=present/absent'

#To  start or restart or reload or stopped of services 'nginx or mysql' in remote hosts
ansible -i inventory.ini all -m 'service' -a 'name=nginx/mysql state=started/restarted/reloaded/stopped'

#To check status of services 'nginx or mysql' in remote hosts which is install
ansible -i inventory.ini all -m service -a 'systemctl status nginx/mysql'

#To create user 
ansible -i inventory.ini all -m user -a 'name=username state=present/absent'

#Using playbook to completed the task
ansible-playbook -i inventory.ini <playbook.yml>


